@page
@model RazorPagesItemsApp.Pages.Items.IndexModel
@{
    ViewData["Title"] = "Items";
}

<section class="page-heading">
    <div>
        <p class="eyebrow">Razor syntax with dynamic data</p>
        <h1>Items</h1>
    </div>
    <a class="button" asp-page="/Items/Create">Add item</a>
</section>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <p class="notice">@Model.Message</p>
}

<table class="items-table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Description</th>
            <th>Quantity</th>
            <th>Added</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Description</td>
                <td>@item.Quantity</td>
                <td>@item.CreatedAt.ToString("dd MMM yyyy")</td>
            </tr>
        }
    </tbody>
</table>
