@model OrderManagementApp.Models.Order

@{
    ViewData["Title"] = "Create New Order - Model-Level Validation Demo";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h1>@ViewData["Title"]</h1>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger alert-dismissible fade show">
                    <strong>Validation Errors:</strong>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    <ul>
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <li>@error.ErrorMessage</li>
                        }
                    </ul>
                </div>
            }

            <form asp-action="Create" method="post" class="needs-validation" novalidate>
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="CustomerId" class="form-label">Customer *</label>
                    <select asp-for="CustomerId" class="form-select">
                        <option value="">-- Select Customer --</option>
                        @foreach (var customer in ViewBag.Customers)
                        {
                            <option value="@customer.CustomerId">@customer.FullName (@customer.Email)</option>
                        }
                    </select>
                    <span asp-validation-for="CustomerId" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="OrderDate" class="form-label">Order Date *</label>
                        <input asp-for="OrderDate" type="date" class="form-control" />
                        <span asp-validation-for="OrderDate" class="text-danger"></span>
                        <small class="form-text text-muted">Model-Level Validation: Will check against Delivery Date</small>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="DeliveryDate" class="form-label">Delivery Date *</label>
                        <input asp-for="DeliveryDate" type="date" class="form-control" />
                        <span asp-validation-for="DeliveryDate" class="text-danger"></span>
                        <small class="form-text text-muted">Must be after order date, within 30 days</small>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Status" class="form-label">Status *</label>
                    <select asp-for="Status" class="form-select">
                        <option value="">-- Select Status --</option>
                        <option value="Pending">Pending</option>
                        <option value="Processing">Processing</option>
                        <option value="Shipped">Shipped</option>
                        <option value="Delivered">Delivered</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                    <small class="form-text text-muted">Model-Level Validation: Must be valid status</small>
                </div>

                <div class="mb-3">
                    <label asp-for="ShippingAddress" class="form-label">Shipping Address</label>
                    <textarea asp-for="ShippingAddress" class="form-control" rows="3" placeholder="Required if Status is Shipped or Delivered"></textarea>
                    <span asp-validation-for="ShippingAddress" class="text-danger"></span>
                    <small class="form-text text-muted">Model-Level Validation: Required for shipped orders</small>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="DiscountAmount" class="form-label">Discount Amount (₹)</label>
                        <input asp-for="DiscountAmount" type="number" step="0.01" class="form-control" />
                        <span asp-validation-for="DiscountAmount" class="text-danger"></span>
                        <small class="form-text text-muted">Model-Level Validation: Cannot exceed order total</small>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="TotalAmount" class="form-label">Total Amount (₹)</label>
                        <input asp-for="TotalAmount" type="number" step="0.01" class="form-control" />
                        <span asp-validation-for="TotalAmount" class="text-danger"></span>
                        <small class="form-text text-muted">Max ₹1,00,00,000</small>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="SpecialInstructions" class="form-label">Special Instructions</label>
                    <textarea asp-for="SpecialInstructions" class="form-control" rows="3"></textarea>
                </div>

                <div class="mb-3">
                    <button type="submit" class="btn btn-success">Create Order</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>

            <div class="mt-4 p-3 bg-light rounded">
                <h6>✓ Model-Level Validation Rules:</h6>
                <ul>
                    <li>Delivery Date must be after Order Date</li>
                    <li>Delivery Date must be within 30 days of Order Date</li>
                    <li>Status must be: Pending, Processing, Shipped, Delivered, or Cancelled</li>
                    <li>Discount cannot exceed total order amount</li>
                    <li>Total amount cannot exceed ₹1,00,00,000</li>
                    <li>Shipping address required for Shipped/Delivered orders</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
