@model MVCDemo.Models.Product

@{
    ViewData["Title"] = "Product Details";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h1>Product Details</h1>

            @if (Model != null)
            {
                <div class="card">
                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-sm-4">Product ID:</dt>
                            <dd class="col-sm-8">@Model.ProductId</dd>

                            <dt class="col-sm-4">Product Name:</dt>
                            <dd class="col-sm-8">@Model.ProductName</dd>

                            <dt class="col-sm-4">Category:</dt>
                            <dd class="col-sm-8">@Model.Category</dd>

                            <dt class="col-sm-4">Price:</dt>
                            <dd class="col-sm-8">₹@Model.Price.ToString("N2")</dd>

                            <dt class="col-sm-4">Stock:</dt>
                            <dd class="col-sm-8">
                                @if (Model.Stock > 0)
                                {
                                    <span class="badge bg-success">@Model.Stock units available</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Out of Stock</span>
                                }
                            </dd>

                            <dt class="col-sm-4">Description:</dt>
                            <dd class="col-sm-8">@Model.Description</dd>
                        </dl>
                    </div>
                </div>

                <div class="mt-3">
                    <!-- TagHelper usage -->
                    <a asp-action="Edit" asp-route-id="@Model.ProductId" class="btn btn-warning">Edit</a>
                    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                </div>
            }
            else
            {
                <div class="alert alert-danger">Product not found.</div>
            }
        </div>
    </div>
</div>
