@model IEnumerable<OrderManagementApp.Models.Order>

@{
    ViewData["Title"] = "Order Management System - Advanced Validation Demo";
}

<div class="container mt-5">
    <h1>@ViewData["Title"]</h1>

    <div class="mb-3">
        <a asp-action="Create" class="btn btn-primary">Create New Order</a>
    </div>

    <!-- Filter Section -->
    <div class="card mb-3">
        <div class="card-body">
            <h5>Filter Orders</h5>
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Customer</label>
                    <select name="customerId" class="form-select">
                        <option value="">-- All Customers --</option>
                        @foreach (var customer in ViewBag.Customers)
                        {
                            <option value="@customer.CustomerId">@customer.FullName</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Status</label>
                    <select name="status" class="form-select">
                        <option value="">-- All Status --</option>
                        <option value="Pending">Pending</option>
                        <option value="Processing">Processing</option>
                        <option value="Shipped">Shipped</option>
                        <option value="Delivered">Delivered</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label>&nbsp;</label>
                    <button type="submit" class="btn btn-success form-control">Filter</button>
                </div>
            </form>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Order ID</th>
                        <th>Customer</th>
                        <th>Order Date</th>
                        <th>Delivery Date</th>
                        <th>Status</th>
                        <th>Amount</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td>@order.OrderId</td>
                            <td>Customer #@order.CustomerId</td>
                            <td>@order.OrderDate.ToShortDateString()</td>
                            <td>@order.DeliveryDate.ToShortDateString()</td>
                            <td>
                                @if (order.Status == "Pending")
                                {
                                    <span class="badge bg-warning">@order.Status</span>
                                }
                                else if (order.Status == "Processing")
                                {
                                    <span class="badge bg-info">@order.Status</span>
                                }
                                else if (order.Status == "Shipped")
                                {
                                    <span class="badge bg-primary">@order.Status</span>
                                }
                                else if (order.Status == "Delivered")
                                {
                                    <span class="badge bg-success">@order.Status</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">@order.Status</span>
                                }
                            </td>
                            <td>₹@order.TotalAmount.ToString("N2")</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@order.OrderId" class="btn btn-sm btn-info">View</a>
                                <a asp-action="Edit" asp-route-id="@order.OrderId" class="btn btn-sm btn-warning">Edit</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">No orders found.</div>
    }

    <div class="mt-4 p-3 bg-light rounded">
        <h6>Model-Level Validation Features:</h6>
        <ul>
            <li>✓ Delivery date must be after order date</li>
            <li>✓ Delivery date max 30 days from order date</li>
            <li>✓ Valid status validation</li>
            <li>✓ Discount amount limit check</li>
            <li>✓ Total order amount limit (₹1 Crore)</li>
            <li>✓ Shipping address required for shipped orders</li>
        </ul>
    </div>
</div>
