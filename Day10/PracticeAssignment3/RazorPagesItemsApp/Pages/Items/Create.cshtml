@page
@model RazorPagesItemsApp.Pages.Items.CreateModel
@{
    ViewData["Title"] = "Add Item";
}

<section class="page-heading">
    <div>
        <p class="eyebrow">PageModel property binding</p>
        <h1>Add Item</h1>
    </div>
    <a class="link-button" asp-page="/Items/Index">View items</a>
</section>

<form method="post" class="item-form">
    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

    <label asp-for="Item.Name"></label>
    <input asp-for="Item.Name" autocomplete="off">
    <span asp-validation-for="Item.Name" class="field-validation"></span>

    <label asp-for="Item.Description"></label>
    <textarea asp-for="Item.Description" rows="4"></textarea>
    <span asp-validation-for="Item.Description" class="field-validation"></span>

    <label asp-for="Item.Quantity"></label>
    <input asp-for="Item.Quantity" type="number" min="1" max="500">
    <span asp-validation-for="Item.Quantity" class="field-validation"></span>

    <button type="submit">Save item</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
