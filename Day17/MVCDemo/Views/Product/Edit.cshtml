@model MVCDemo.Models.Product

@{
    ViewData["Title"] = "Edit Product";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h1>@ViewData["Title"]</h1>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger alert-dismissible fade show">
                    <strong>Validation Errors:</strong>
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                </div>
            }

            <form asp-action="Edit" asp-route-id="@Model.ProductId" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label">Product ID</label>
                    <input type="text" class="form-control" value="@Model.ProductId" disabled />
                    <input type="hidden" asp-for="ProductId" />
                </div>

                <div class="mb-3">
                    <label asp-for="ProductName" class="form-label">Product Name *</label>
                    <input asp-for="ProductName" class="form-control" />
                    <span asp-validation-for="ProductName" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Price" class="form-label">Price (₹) *</label>
                        <input asp-for="Price" type="number" step="0.01" class="form-control" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Stock" class="form-label">Stock Quantity *</label>
                        <input asp-for="Stock" type="number" class="form-control" />
                        <span asp-validation-for="Stock" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Category" class="form-label">Category *</label>
                    <select asp-for="Category" class="form-select">
                        <option value="">-- Select Category --</option>
                        <option value="Electronics" selected="@(Model.Category == "Electronics")">Electronics</option>
                        <option value="Clothing" selected="@(Model.Category == "Clothing")">Clothing</option>
                        <option value="Books" selected="@(Model.Category == "Books")">Books</option>
                        <option value="Home" selected="@(Model.Category == "Home")">Home & Garden</option>
                        <option value="Sports" selected="@(Model.Category == "Sports")">Sports</option>
                    </select>
                    <span asp-validation-for="Category" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <button type="submit" class="btn btn-primary">Update Product</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
