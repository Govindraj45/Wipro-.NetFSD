<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Online Bookstore</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 2rem; color: #1e1f24; }
        nav { display: flex; gap: 1rem; margin-bottom: 1rem; }
        form, table { width: 100%; }
        input, textarea, button { padding: .55rem; margin: .25rem 0; }
        table { border-collapse: collapse; }
        td, th { border-bottom: 1px solid #ddd; padding: .65rem; text-align: left; }
        .validation-summary-errors { color: #b42318; }
        .field-validation-error { color: #b42318; font-size: .9rem; }
    </style>
</head>
<body>
    <nav>
        <a asp-controller="Books" asp-action="Index">Catalog</a>
        <a asp-page="/Cart/Index">Cart</a>
        <a asp-controller="Orders" asp-action="Summary">Orders</a>
        <a asp-page="/Books/Manage">Manage Books</a>
        <a asp-page="/Account/Login">Login</a>
        <a asp-page="/Account/Register">Register</a>
    </nav>
    @RenderBody()
</body>
</html>
