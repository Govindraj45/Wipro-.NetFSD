@model PersonInputModel

<h1>MVC Model Binding Workshop</h1>
<form asp-action="Submit" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All"></div>
    <input asp-for="FirstName" placeholder="First name" />
    <span asp-validation-for="FirstName"></span>
    <input asp-for="LastName" placeholder="Last name" />
    <span asp-validation-for="LastName"></span>
    <input asp-for="Age" placeholder="Age" />
    <span asp-validation-for="Age"></span>
    <input asp-for="Address.Street" placeholder="Street" />
    <span asp-validation-for="Address.Street"></span>
    <input asp-for="Address.City" placeholder="City" />
    <span asp-validation-for="Address.City"></span>
    <input asp-for="Address.ZipCode" placeholder="Zip code" />
    <span asp-validation-for="Address.ZipCode"></span>
    <button type="submit">Submit</button>
</form>
