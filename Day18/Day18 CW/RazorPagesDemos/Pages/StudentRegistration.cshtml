@page
@model RazorPagesDemos.Pages.StudentRegistrationModel
@{
    ViewData["Title"] = "Student Registration";
}

<div class="text-center">
    <h2 class="display-4">Student Registration</h2>
    <p>Please enter your name below.</p>
</div>

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <form method="post">
                    <div class="mb-3">
                        <label asp-for="StudentName" class="form-label">Enter Name:</label>
                        <input asp-for="StudentName" class="form-control" placeholder="John Doe" />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Register</button>
                </form>

                @if (Model.Message != null)
                {
                    <div class="alert alert-success mt-4" role="alert">
                        @Model.Message
                    </div>
                }
            </div>
        </div>
    </div>
</div>
