@page
@model RazorPagesDemo.Pages.SuccessModel

@{
    ViewData["Title"] = "Student Registered Successfully";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="alert alert-success">
                <h1>✓ Success!</h1>
                <p class="lead">Student has been registered successfully.</p>
            </div>

            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Registration Confirmed</h5>
                    <p>Student ID: <strong>@Model.StudentId</strong></p>
                    <p>You can now return to the registration page to add more students.</p>

                    <a href="/Register" class="btn btn-primary">Back to Registration</a>
                    <a href="/" class="btn btn-secondary">Home</a>
                </div>
            </div>
        </div>
    </div>
</div>
