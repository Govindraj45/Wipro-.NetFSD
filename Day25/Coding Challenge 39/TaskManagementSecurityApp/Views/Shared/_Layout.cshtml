<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Task Management Security App</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 2rem; }
        nav { display: flex; gap: 1rem; margin-bottom: 1rem; }
        input, textarea, button { padding: .55rem; margin: .25rem 0; width: 100%; max-width: 420px; }
        .field-validation-error, .validation-summary-errors { color: #b42318; }
    </style>
</head>
<body>
    <nav>
        <a asp-controller="Account" asp-action="Login">Login</a>
        <a asp-controller="Account" asp-action="Register">Register</a>
        <a asp-controller="User" asp-action="TaskList">My Tasks</a>
        <a asp-controller="Admin" asp-action="ManageTasks">Admin Tasks</a>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline">
                @Html.AntiForgeryToken()
                <button type="submit" style="width:auto">Logout</button>
            </form>
        }
    </nav>
    @RenderBody()
</body>
</html>
